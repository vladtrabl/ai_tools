{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOOKS_DIR/git-safety.sh\"",
            "timeout": 10,
            "statusMessage": "Checking git safety..."
          },
          {
            "type": "command",
            "command": "bash \"$HOOKS_DIR/destructive-guard.sh\"",
            "timeout": 10,
            "statusMessage": "Checking for destructive commands..."
          },
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "bash \"$HOOKS_DIR/commit-msg-check.sh\"",
            "timeout": 10,
            "statusMessage": "Validating commit message..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOOKS_DIR/file-write-guard.sh\"",
            "timeout": 10,
            "statusMessage": "Checking file write safety..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOOKS_DIR/agent-audit.sh\"",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOOKS_DIR/compact-reinject.sh\"",
            "timeout": 10,
            "statusMessage": "Reinjecting orchestration context..."
          }
        ]
      }
    ]
  }
}
